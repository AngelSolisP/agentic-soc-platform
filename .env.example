# ============================================================
# Agentic SOC - MSSP Platform — Environment Variables
# Copy to .env and fill in values. NEVER commit .env to git.
# ============================================================

# --- Partner GCP Project (central platform) ---
PARTNER_PROJECT_ID=your-partner-project-id
PARTNER_REGION=us-central1

# --- Vertex AI ---
VERTEX_AI_LOCATION=us-central1
GEMINI_FLASH_MODEL=gemini-2.5-flash
GEMINI_PRO_MODEL=gemini-2.5-pro

# --- Service Account (proxy / agent runner) ---
# In production this is handled by Workload Identity / ADC.
# For local dev only:
GOOGLE_APPLICATION_CREDENTIALS=/path/to/sa-key.json

# --- MCP Gateway ---
MCP_GATEWAY_PORT=8080
MCP_GATEWAY_HOST=0.0.0.0
MCP_CHRONICLE_REGION=us  # or eu, asia

# --- Firestore ---
FIRESTORE_DATABASE=(default)

# --- Secret Manager ---
SECRET_MANAGER_PREFIX=agentic-soc

# --- HITL Dashboard ---
HITL_BACKEND_PORT=8081
HITL_FRONTEND_PORT=3000

# --- Agent Execution ---
AGENT_TIMEOUT_SECONDS=300  # 5 minutes max per alert processing

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json  # json | text

# --- Model Armor ---
MODEL_ARMOR_ENABLED=true
MODEL_ARMOR_TEMPLATE_ID=agentic-soc-default

# --- Authentication ---
# Comma-separated API keys for development/external integrations
API_KEYS=
# Comma-separated allowed caller emails (empty = any verified Google identity)
ALLOWED_CALLERS=
# Comma-separated CORS origins (empty = localhost defaults)
CORS_ORIGINS=

# --- HITL Two-Pass ---
APPROVAL_CALLBACK_URL=  # e.g. https://agentic-soc-hitl-staging-xxx.run.app/approvals/{approval_id}/execute
ENFORCE_CLIENT_AUTH=true
HITL_BACKEND_URL=http://localhost:8081
HITL_AUTH_TOKEN=  # Auth token for Streamlit → HITL backend

# --- Agent Orchestrator ---
MCP_GATEWAY_URL=http://localhost:8080
USE_VERTEX_SESSION_SERVICE=false  # true in production (persists sessions in Vertex AI)

# --- GTI MCP ---
GTI_MCP_URL=http://localhost:8081/mcp

# --- Model Armor ---
MODEL_ARMOR_FAIL_MODE=FAIL_CLOSED  # FAIL_OPEN for initial testing

# --- Observability ---
OTEL_EXPORTER_TYPE=console  # console | cloud (OTLP → Cloud Trace)
ENVIRONMENT=local  # local | staging | production

# --- Google Env (auto-injected by Agent Engine / Cloud Run) ---
GOOGLE_GENAI_USE_VERTEXAI=true
# GOOGLE_CLOUD_PROJECT=your-project-id  # auto-injected by Cloud Run
# GOOGLE_CLOUD_LOCATION=us-central1     # auto-injected by Cloud Run

# --- Development ---
DEV_MODE=true  # Set to false in production — disables auth bypass
NFR_CLIENT_ID=nfr-partner-client  # First client = partner's NFR instance
